# Project 10 – Creative Content Generation Platform – Local Development .env
# Copy to .env and fill in values before running locally

# ─── RHOAI Model Serving (Llama 3 8B – vLLM) ────────────────────────────────
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=your-rhoai-token-here
LLM_MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# ─── RHOAI ModelMesh (E5-large embeddings) ──────────────────────────────────
EMBEDDING_BASE_URL=http://localhost:8001/v1
EMBEDDING_MODEL_NAME=intfloat/e5-large-v2
EMBEDDING_DIMENSION=1024

# ─── RHOAI ModelMesh (NLLB-200 translation) ─────────────────────────────────
TRANSLATION_BASE_URL=http://localhost:8002/v1
TRANSLATION_MODEL_NAME=facebook/nllb-200-distilled-600M

# ─── Weaviate ─────────────────────────────────────────────────────────────────
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_API_KEY=
WEAVIATE_BRAND_CLASS=BrandGuideline
WEAVIATE_ASSET_CLASS=CreativeAsset

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_ASSET_TTL=604800

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://contentuser:contentpass@localhost:5432/creative

# ─── ODF S3 ──────────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET_ASSETS=creative-assets
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ─── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ─── Compliance ──────────────────────────────────────────────────────────────
COMPLIANCE_THRESHOLD=0.8

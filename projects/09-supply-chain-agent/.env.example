# Project 9 – Supply Chain Optimization Agent – Local Development .env

# Service
SERVICE_NAME=supply-chain-agent
LOG_LEVEL=DEBUG
CORS_ORIGINS=["*"]

# LLM (RHOAI vLLM – Llama 3 8B)
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=your-rhoai-token-here
LLM_MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.2

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=supplier_knowledge

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_SESSION_TTL=86400

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_INVENTORY=supply.inventory
KAFKA_TOPIC_ORDERS=supply.orders

# Database
DATABASE_URL=postgresql://supplyuser:supplypass@localhost:5432/supplydb

# Agent behaviour
MAX_AGENT_ITERATIONS=5
RISK_ALERT_THRESHOLD=0.7

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=supply-chain-agent

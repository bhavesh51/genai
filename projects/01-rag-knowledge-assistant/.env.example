# Project 1 – RAG Knowledge Assistant – Local Development .env
# Copy to .env and fill in values before running locally

# ─── RHOAI Model Serving ────────────────────────────────────────────────
LLM_BASE_URL=https://granite-vllm.rhoai-serving.svc.cluster.local/v1
LLM_API_KEY=your-rhoai-token-here
LLM_MODEL_NAME=ibm-granite/granite-3.1-8b-instruct
EMBEDDING_BASE_URL=https://embedding-modelmesh.rhoai-serving.svc.cluster.local/v1
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# ─── Milvus ─────────────────────────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=milvus

# ─── ODF S3 ─────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET_AUDIT=rag-audit-logs
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ─── Observability ───────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Project 6 – E-commerce Product Recommendation Engine – Local Development .env
# Copy to .env and fill in values before running locally

# ─── RHOAI Model Serving (Llama 3 8B – vLLM) ────────────────────────────────
LLM_BASE_URL=https://llama3-8b-vllm.rhoai-serving.svc.cluster.local/v1
LLM_API_KEY=your-rhoai-token-here
LLM_MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct

# ─── RHOAI ModelMesh (E5-large embeddings) ──────────────────────────────────
EMBEDDING_BASE_URL=https://e5-large-modelmesh.rhoai-serving.svc.cluster.local/v1
EMBEDDING_MODEL_NAME=intfloat/e5-large-v2

# ─── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=product_embeddings

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://recuser:recpass@localhost:5432/ecommerce

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_EVENTS=ecommerce.events
KAFKA_TOPIC_CATALOGUE=ecommerce.catalogue

# ─── ODF S3 ──────────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET_MODELS=rec-engine-models
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ─── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

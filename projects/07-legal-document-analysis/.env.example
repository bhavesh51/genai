# Project 7 – Legal Document Analysis & Contract Intelligence – Local Development .env
# Copy to .env and fill in values before running locally

# ─── Service ─────────────────────────────────────────────────────────────────
SERVICE_NAME=legal-document-analysis
LOG_LEVEL=DEBUG

# ─── RHOAI Model Serving (Llama 3 8B – vLLM) ────────────────────────────────
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=your-rhoai-token-here
LLM_MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# ─── RHOAI ModelMesh (InLegalBERT embeddings) ───────────────────────────────
EMBEDDING_BASE_URL=http://localhost:8001/v1
EMBEDDING_MODEL_NAME=law-ai/InLegalBERT
EMBEDDING_DIMENSION=768

# ─── Weaviate ─────────────────────────────────────────────────────────────────
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_API_KEY=
WEAVIATE_CLASS=LegalClause

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DOC_TTL=86400

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://legaluser:legalpass@localhost:5432/legaldb

# ─── ODF S3 ──────────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET_DOCS=legal-documents
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ─── Observability ───────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=legal-document-analysis

# ─── Processing limits ────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
MIN_CLAUSE_LENGTH=50
RISK_THRESHOLD=0.45
